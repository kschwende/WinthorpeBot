# WinthorpeBot — own credentials, fully independent of upstream.
# Copy to .env (gitignored) and fill in. This tastytrade session is SEPARATE
# from the upstream live stack — its own OAuth secret + refresh token.

# tastytrade OAuth (https://developer.tastytrade.com)
TT_SECRET=
TT_REFRESH=

# Safety: live execution is OFF unless this file exists AND WINTHORPE_LIVE=1.
# Leave unset / 0 for DRY-RUN (orders logged, never sent).
WINTHORPE_LIVE=0
